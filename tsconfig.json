{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ES2022",
    "target": "ES2022",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "types": ["node"],
    "strictNullChecks": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "skipLibCheck": true
  },
  "include": ["**/*.ts"]
}
